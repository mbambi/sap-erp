# Database (SQLite default, switch to PostgreSQL for production)
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:password@localhost:5432/saperp?schema=public"

# JWT
JWT_SECRET="change-me-to-a-strong-random-secret"
JWT_EXPIRY="8h"

# Server
PORT=3001
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173

# Redis (optional - for background job processing)
REDIS_URL=redis://localhost:6379

# Client
VITE_API_URL=http://localhost:3001/api

# SSO (optional)
SAML_ENTRY_POINT=""
SAML_ISSUER=""
OAUTH2_CLIENT_ID=""
OAUTH2_CLIENT_SECRET=""
OAUTH2_CALLBACK_URL=""

# LDAP (optional)
LDAP_URL=""
LDAP_BIND_DN=""
LDAP_BIND_PASSWORD=""
LDAP_SEARCH_BASE=""
