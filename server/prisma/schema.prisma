  equipment Equipment @relation(fields: [equipmentId], references: [id])

  @@unique([tenantId, woNumber])
}

model MaintenancePlan {
  id            String @id @default(uuid())
  equipmentId   String
  name          String
  type          String // time_based, counter_based, condition_based
  intervalDays  Int?
  intervalHours Int?
  lastExecuted  DateTime?
  nextDue       DateTime?
  isActive      Boolean @default(true)
  createdAt     DateTime @default(now())

  equipment Equipment @relation(fields: [equipmentId], references: [id])
}

// ─── Human Resources (HR) ───────────────────────────────────────────

model Employee {
  id             String   @id @default(uuid())
  tenantId       String
  employeeNumber String
  firstName      String
  lastName       String
  email          String?
  phone          String?
  dateOfBirth    DateTime?
  hireDate       DateTime
  terminationDate DateTime?
  department     String?
  position       String?
  managerId      String?
  plantId        String?
  orgUnitId      String?
  employmentType String   @default("full_time") // full_time, part_time, contractor, intern
  status         String   @default("active") // active, on_leave, terminated
  salary         Float?
  currency       String   @default("USD")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant  Tenant     @relation(fields: [tenantId], references: [id])
  plant   Plant?     @relation(fields: [plantId], references: [id])
  manager Employee?  @relation("ManagerRelation", fields: [managerId], references: [id])
  reports Employee[] @relation("ManagerRelation")
  orgUnit OrgUnit?   @relation(fields: [orgUnitId], references: [id])
  leaves  LeaveRequest[]
  timeEntries TimeEntry[]

