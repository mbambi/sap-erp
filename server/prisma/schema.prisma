generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Notifications ────────────────────────────────────────────────────

model Notification {
  id          String   @id @default(uuid())
  tenantId    String
  userId      String
  type        String   // info, warning, success, error, achievement, system
  title       String
  message     String
  module      String?
  link        String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, userId, isRead])
}

// ─── User Profile Extensions ──────────────────────────────────────────

model UserProfile {
  id          String  @id @default(uuid())
  userId      String  @unique
  tenantId    String
  avatar      String?
  bio         String?
  department  String?
  title       String?
  phone       String?
  timezone    String  @default("UTC")
  language    String  @default("en")
  theme       String  @default("light")
  emailNotifications Boolean @default(true)
  dashboardLayout    String? // JSON
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

// ─── Student Sandbox Companies ────────────────────────────────────────

model StudentCompany {
  id          String   @id @default(uuid())
  tenantId    String
  userId      String
  companyName String
  industry    String   @default("manufacturing")
  description String?
  cashBalance Float    @default(100000)
  revenue     Float    @default(0)
  expenses    Float    @default(0)
  profit      Float    @default(0)
  inventoryValue Float @default(0)
  serviceLevel Float   @default(100)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, userId])
}

// ─── Supply Chain Game Mode ───────────────────────────────────────────

model GameSession {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  status      String   @default("lobby") // lobby, active, completed
  startDate   DateTime?
  endDate     DateTime?
  duration    Int      @default(30) // game days
  currentDay  Int      @default(0)
  settings    String   // JSON: difficulty, events enabled, etc.
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant       @relation(fields: [tenantId], references: [id])
  players GamePlayer[]
}

model GamePlayer {
  id              String   @id @default(uuid())
  gameSessionId   String
  userId          String
  companyName     String
  revenue         Float    @default(0)
  totalCost       Float    @default(0)
  profit          Float    @default(0)
  inventoryTurnover Float  @default(0)
  serviceLevel    Float    @default(100)
  cashFlow        Float    @default(0)
  onTimeDelivery  Float    @default(100)
  qualityScore    Float    @default(100)
  overallScore    Float    @default(0)
  rank            Int      @default(0)
  decisions       String?  // JSON: array of decisions made
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  gameSession GameSession @relation(fields: [gameSessionId], references: [id], onDelete: Cascade)

  @@unique([gameSessionId, userId])
}

// ─── Job Queue Tracking ───────────────────────────────────────────────

model BackgroundJob {
  id          String   @id @default(uuid())
  tenantId    String
  type        String   // mrp_run, simulation, dataset_generation, report_generation
  status      String   @default("queued") // queued, processing, completed, failed
  payload     String   // JSON input
  result      String?  // JSON output
  error       String?
  progress    Int      @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  createdBy   String
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
}

// ─── Multi-Tenancy & Auth ────────────────────────────────────────────

model Tenant {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  university  String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users             User[]
  roles             Role[]
  companyCode       CompanyCode[]
  plants            Plant[]
  glAccounts        GLAccount[]
  journals          JournalEntry[]
  vendors           Vendor[]
  customers         Customer[]
  purchaseOrders    PurchaseOrder[]
  salesOrders       SalesOrder[]
  materials         Material[]
  boms              BillOfMaterial[]
  productionOrders  ProductionOrder[]
  warehouses        Warehouse[]
  equipment         Equipment[]
  workOrders        WorkOrder[]
  employees         Employee[]
  costCenters       CostCenter[]
  internalOrders    InternalOrder[]
  workflows         WorkflowDefinition[]
  exercises         Exercise[]
  scenarios         Scenario[]
  auditLogs         AuditLog[]
  inspectionLots    InspectionLot[]
  nonConformances   NonConformance[]
  reports           SavedReport[]
  mrpRuns           MrpRun[]
  demandForecasts   DemandForecast[]
  plannedOrders     PlannedOrder[]
  workCenters       WorkCenter[]
  productionSchedules ProductionSchedule[]
  supplyChainNodes  SupplyChainNode[]
  supplyChainLinks  SupplyChainLink[]
  processEvents     ProcessEvent[]
  inventoryPolicies InventoryPolicy[]
  userXP            UserXP[]
  operationsMetrics OperationsMetric[]
  fiscalPeriods     FiscalPeriod[]
  purchaseRequisitions PurchaseRequisition[]
  supplierInvoices  SupplierInvoice[]
  payments          Payment[]
  pricingConditions PricingCondition[]
  shipments         Shipment[]
  assets            Asset[]
  costEstimates     CostEstimate[]
  erpEvents         ERPEvent[]
  simulationSessions SimulationSession[]
  instructorActions InstructorAction[]
  companies         Company[]
  intercompanyTxns  IntercompanyTransaction[]
  transferPricingRules TransferPricingRule[]
  financialStatements FinancialStatement[]
  closingPeriods    ClosingPeriod[]
  portalAccesses    PortalAccess[]
  factSales         FactSales[]
  factInventory     FactInventory[]
  optimizationRuns  OptimizationRun[]
  integrationEndpoints IntegrationEndpoint[]
  integrationLogs   IntegrationLog[]
  documents         Document[]
  systemMetrics     SystemMetric[]
  courses           Course[]
  certifications    Certification[]
  datasetTemplates  DatasetTemplate[]
  processFlows      ProcessFlow[]
  digitalTwinStates DigitalTwinState[]
  industryTemplates IndustryTemplate[]
  decisionImpacts   DecisionImpact[]
  benchmarkRuns     BenchmarkRun[]
  stressTests       StressTest[]
  userPresences     UserPresence[]
  notifications     Notification[]
  userProfiles      UserProfile[]
  studentCompanies  StudentCompany[]
  gameSessions      GameSession[]
  backgroundJobs    BackgroundJob[]
}

model User {
  id             String   @id @default(uuid())
  tenantId       String
  email          String
  passwordHash   String
  firstName      String
  lastName       String
  isActive       Boolean  @default(true)
  lastLogin      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  userRoles      UserRole[]
  auditLogs      AuditLog[]
  workflowTasks  WorkflowTask[]
  exerciseProgress ExerciseProgress[]

  @@unique([tenantId, email])
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  userRoles   UserRole[]
  permissions RolePermission[]

  @@unique([tenantId, name])
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
}

model RolePermission {
  id         String @id @default(uuid())
  roleId     String
  module     String
  action     String // create, read, update, delete, approve, export
  resource   String // e.g. "journal_entry", "purchase_order"

  role Role @relation(fields: [roleId], references: [id])

  @@unique([roleId, module, action, resource])
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String?
  action     String
  module     String
  resource   String
  resourceId String?
  oldValue   String?  // JSON
  newValue   String?  // JSON
  ipAddress  String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])
}

// ─── Finance (FI) ────────────────────────────────────────────────────

model CompanyCode {
  id          String @id @default(uuid())
  tenantId    String
  code        String
  name        String
  currency    String @default("USD")
  country     String @default("US")
  fiscalYear  String @default("calendar") // calendar or custom
  createdAt   DateTime @default(now())

  tenant     Tenant        @relation(fields: [tenantId], references: [id])
  glAccounts GLAccount[]
  journals   JournalEntry[]

  @@unique([tenantId, code])
}

model GLAccount {
  id            String  @id @default(uuid())
  tenantId      String
  companyCodeId String
  accountNumber String
  name          String
  type          String  // asset, liability, equity, revenue, expense
  parentId      String?
  isActive      Boolean @default(true)
  currency      String  @default("USD")
  createdAt     DateTime @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  companyCode CompanyCode @relation(fields: [companyCodeId], references: [id])
  parent      GLAccount?  @relation("GLAccountHierarchy", fields: [parentId], references: [id])
  children    GLAccount[] @relation("GLAccountHierarchy")
  lineItems   JournalLineItem[]

  @@unique([tenantId, companyCodeId, accountNumber])
}

model JournalEntry {
  id            String   @id @default(uuid())
  tenantId      String
  companyCodeId String
  documentNumber String
  postingDate   DateTime
  documentDate  DateTime
  description   String?
  reference     String?
  status        String   @default("draft") // draft, posted, reversed
  reversalOf    String?
  createdBy     String
  createdAt     DateTime @default(now())

  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  companyCode CompanyCode       @relation(fields: [companyCodeId], references: [id])
  lineItems   JournalLineItem[]

  @@unique([tenantId, companyCodeId, documentNumber])
}

model JournalLineItem {
  id             String  @id @default(uuid())
  journalEntryId String
  glAccountId    String
  lineNumber     Int
  debit          Float   @default(0)
  credit         Float   @default(0)
  description    String?
  costCenterId   String?
  internalOrderId String?
  profitCenterId  String?

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  glAccount    GLAccount    @relation(fields: [glAccountId], references: [id])
}

model Vendor {
  id            String   @id @default(uuid())
  tenantId      String
  vendorNumber  String
  name          String
  street        String?
  city          String?
  state         String?
  postalCode    String?
  country       String   @default("US")
  phone         String?
  email         String?
  taxId         String?
  paymentTerms  String   @default("NET30")
  currency      String   @default("USD")
  bankAccount   String?
  bankRouting   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  purchaseOrders PurchaseOrder[]

  @@unique([tenantId, vendorNumber])
}

model Customer {
  id              String   @id @default(uuid())
  tenantId        String
  customerNumber  String
  name            String
  street          String?
  city            String?
  state           String?
  postalCode      String?
  country         String   @default("US")
  phone           String?
  email           String?
  taxId           String?
  paymentTerms    String   @default("NET30")
  creditLimit     Float    @default(0)
  currency        String   @default("USD")
  priceList       String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  salesOrders SalesOrder[]
  deliveries  Delivery[]
  invoices    Invoice[]

  @@unique([tenantId, customerNumber])
}

model FixedAsset {
  id              String   @id @default(uuid())
  assetNumber     String
  description     String
  acquisitionDate DateTime
  acquisitionCost Float
  usefulLifeYears Int
  depreciationMethod String @default("straight-line")
  salvageValue    Float    @default(0)
  accumulatedDepreciation Float @default(0)
  status          String   @default("active") // active, disposed, transferred
  location        String?
  costCenterId    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model BankAccount {
  id            String @id @default(uuid())
  accountName   String
  bankName      String
  accountNumber String
  routingNumber String?
  iban          String?
  swift         String?
  currency      String @default("USD")
  balance       Float  @default(0)
  isActive      Boolean @default(true)
  createdAt     DateTime @default(now())
}

// ─── Materials Management (MM) ───────────────────────────────────────

model Plant {
  id       String @id @default(uuid())
  tenantId String
  code     String
  name     String
  address  String?
  isActive Boolean @default(true)

  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  warehouses  Warehouse[]
  equipment   Equipment[]
  employees   Employee[]

  @@unique([tenantId, code])
}

model Material {
  id              String   @id @default(uuid())
  tenantId        String
  materialNumber  String
  description     String
  type            String   // raw, semi-finished, finished, trading, service
  baseUnit        String   @default("EA")
  materialGroup   String?
  weight          Float?
  weightUnit      String?
  volume          Float?
  volumeUnit      String?
  standardPrice   Float    @default(0)
  movingAvgPrice  Float    @default(0)
  lotSize         Int      @default(1)
  safetyStock     Int      @default(0)
  reorderPoint    Int      @default(0)
  leadTimeDays    Int      @default(0)
  stockQuantity   Int      @default(0)
  reservedQty     Int      @default(0)
  valuationClass  String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant           Tenant              @relation(fields: [tenantId], references: [id])
  poItems          PurchaseOrderItem[]
  soItems          SalesOrderItem[]
  bomParent        BillOfMaterial[]    @relation("BOMParent")
  bomComponents    BOMComponent[]
  inventoryMovements InventoryMovement[]
  warehouseBins    WarehouseBin[]
  inspectionLots   InspectionLot[]

  @@unique([tenantId, materialNumber])
}

model PurchaseOrder {
  id              String   @id @default(uuid())
  tenantId        String
  poNumber        String
  vendorId        String
  orderDate       DateTime @default(now())
  deliveryDate    DateTime?
  status          String   @default("draft") // draft, approved, ordered, received, closed, cancelled
  totalAmount     Float    @default(0)
  currency        String   @default("USD")
  paymentTerms    String   @default("NET30")
  notes           String?
  approvedBy      String?
  approvedAt      DateTime?
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant              @relation(fields: [tenantId], references: [id])
  vendor Vendor              @relation(fields: [vendorId], references: [id])
  items  PurchaseOrderItem[]
  goodsReceipts GoodsReceipt[]

  @@unique([tenantId, poNumber])
}

model PurchaseOrderItem {
  id          String @id @default(uuid())
  poId        String
  lineNumber  Int
  materialId  String
  quantity    Int
  unit        String @default("EA")
  unitPrice   Float
  totalPrice  Float
  deliveryDate DateTime?
  receivedQty Int    @default(0)

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  material      Material      @relation(fields: [materialId], references: [id])
}

model GoodsReceipt {
  id        String   @id @default(uuid())
  poId      String
  grNumber  String
  receiptDate DateTime @default(now())
  notes     String?
  createdBy String
  createdAt DateTime @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id])
  items         GoodsReceiptItem[]
}

model GoodsReceiptItem {
  id            String @id @default(uuid())
  goodsReceiptId String
  materialId    String
  quantity      Int
  batchNumber   String?
  storageLocation String?

  goodsReceipt GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
}

model InventoryMovement {
  id          String   @id @default(uuid())
  materialId  String
  movementType String  // receipt, issue, transfer, adjustment, scrap
  quantity    Int
  unit        String   @default("EA")
  fromLocation String?
  toLocation   String?
  reference   String?
  reason      String?
  createdBy   String
  createdAt   DateTime @default(now())

  material Material @relation(fields: [materialId], references: [id])
}

// ─── Sales & Distribution (SD) ───────────────────────────────────────

model SalesOrder {
  id             String   @id @default(uuid())
  tenantId       String
  soNumber       String
  customerId     String
  orderDate      DateTime @default(now())
  requestedDate  DateTime?
  status         String   @default("draft") // draft, confirmed, processing, shipped, completed, cancelled
  totalAmount    Float    @default(0)
  currency       String   @default("USD")
  paymentTerms   String   @default("NET30")
  shippingMethod String?
  notes          String?
  createdBy      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  customer  Customer         @relation(fields: [customerId], references: [id])
  items     SalesOrderItem[]
  deliveries Delivery[]
  invoices   Invoice[]

  @@unique([tenantId, soNumber])
}

model SalesOrderItem {
  id          String @id @default(uuid())
  soId        String
  lineNumber  Int
  materialId  String
  quantity    Int
  unit        String @default("EA")
  unitPrice   Float
  discount    Float  @default(0)
  totalPrice  Float
  deliveredQty Int   @default(0)

  salesOrder SalesOrder @relation(fields: [soId], references: [id], onDelete: Cascade)
  material   Material   @relation(fields: [materialId], references: [id])
}

model Delivery {
  id           String   @id @default(uuid())
  deliveryNumber String
  soId         String
  customerId   String
  deliveryDate DateTime @default(now())
  status       String   @default("planned") // planned, picked, packed, shipped, delivered
  trackingNumber String?
  carrier      String?
  notes        String?
  createdBy    String
  createdAt    DateTime @default(now())

  salesOrder SalesOrder     @relation(fields: [soId], references: [id])
  customer   Customer       @relation(fields: [customerId], references: [id])
  items      DeliveryItem[]
}

model DeliveryItem {
  id         String @id @default(uuid())
  deliveryId String
  materialId String
  quantity   Int
  batchNumber String?

  delivery Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
}

model Invoice {
  id            String   @id @default(uuid())
  invoiceNumber String
  soId          String
  customerId    String
  invoiceDate   DateTime @default(now())
  dueDate       DateTime
  status        String   @default("draft") // draft, sent, paid, overdue, cancelled
  subtotal      Float
  taxAmount     Float    @default(0)
  totalAmount   Float
  paidAmount    Float    @default(0)
  currency      String   @default("USD")
  notes         String?
  createdBy     String
  createdAt     DateTime @default(now())

  salesOrder SalesOrder    @relation(fields: [soId], references: [id])
  customer   Customer      @relation(fields: [customerId], references: [id])
  items      InvoiceItem[]
}

model InvoiceItem {
  id         String @id @default(uuid())
  invoiceId  String
  description String
  quantity   Int
  unitPrice  Float
  totalPrice Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

// ─── Production Planning (PP) ────────────────────────────────────────

model BillOfMaterial {
  id          String @id @default(uuid())
  tenantId    String
  bomNumber   String
  materialId  String // finished product
  description String?
  version     Int    @default(1)
  isActive    Boolean @default(true)
  validFrom   DateTime @default(now())
  validTo     DateTime?
  createdAt   DateTime @default(now())

  tenant     Tenant         @relation(fields: [tenantId], references: [id])
  material   Material       @relation("BOMParent", fields: [materialId], references: [id])
  components BOMComponent[]
  routings   Routing[]

  @@unique([tenantId, bomNumber])
}

model BOMComponent {
  id          String @id @default(uuid())
  bomId       String
  materialId  String
  quantity    Float
  unit        String  @default("EA")
  position    Int
  isPhantom   Boolean @default(false)
  scrapRate   Float   @default(0)

  bom      BillOfMaterial @relation(fields: [bomId], references: [id], onDelete: Cascade)
  material Material       @relation(fields: [materialId], references: [id])
}

model Routing {
  id     String @id @default(uuid())
  bomId  String
  stepNo Int
  workCenter String
  operation  String
  description String?
  setupTime   Float @default(0) // hours
  runTime     Float @default(0) // hours per unit
  laborRate   Float @default(0)
  machineRate Float @default(0)

  bom BillOfMaterial @relation(fields: [bomId], references: [id], onDelete: Cascade)
}

model ProductionOrder {
  id            String   @id @default(uuid())
  tenantId      String
  orderNumber   String
  materialId    String
  quantity      Int
  unit          String   @default("EA")
  plannedStart  DateTime
  plannedEnd    DateTime
  actualStart   DateTime?
  actualEnd     DateTime?
  status        String   @default("planned") // planned, released, in_progress, completed, closed
  priority      Int      @default(5)
  yieldQty      Int      @default(0)
  scrapQty      Int      @default(0)
  notes         String?
  createdBy     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, orderNumber])
}

// ─── Warehouse Management (WM) ──────────────────────────────────────

model Warehouse {
  id       String @id @default(uuid())
  tenantId String
  plantId  String
  code     String
  name     String
  type     String @default("standard") // standard, cold, hazmat, staging
  isActive Boolean @default(true)

  tenant Tenant        @relation(fields: [tenantId], references: [id])
  plant  Plant         @relation(fields: [plantId], references: [id])
  bins   WarehouseBin[]

  @@unique([tenantId, code])
}

model WarehouseBin {
  id          String @id @default(uuid())
  warehouseId String
  binCode     String
  zone        String?
  aisle       String?
  rack        String?
  level       String?
  materialId  String?
  quantity    Int     @default(0)
  maxCapacity Int     @default(1000)
  binType     String  @default("storage") // storage, picking, receiving, shipping

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  material  Material? @relation(fields: [materialId], references: [id])

  @@unique([warehouseId, binCode])
}

// ─── Quality Management (QM) ────────────────────────────────────────

model InspectionLot {
  id            String   @id @default(uuid())
  tenantId      String
  lotNumber     String
  materialId    String
  quantity      Int
  origin        String   // goods_receipt, production, return
  referenceDoc  String?
  status        String   @default("created") // created, in_inspection, accepted, rejected, use_decision
  inspectedQty  Int      @default(0)
  defectiveQty  Int      @default(0)
  inspectedBy   String?
  inspectedAt   DateTime?
  createdAt     DateTime @default(now())

  tenant   Tenant     @relation(fields: [tenantId], references: [id])
  material Material   @relation(fields: [materialId], references: [id])
  results  InspectionResult[]
  nonConformances NonConformance[]

  @@unique([tenantId, lotNumber])
}

model InspectionResult {
  id              String @id @default(uuid())
  inspectionLotId String
  characteristic  String
  specification   String?
  measuredValue   String?
  result          String // pass, fail, conditional
  notes           String?
  inspectedBy     String
  inspectedAt     DateTime @default(now())

  inspectionLot InspectionLot @relation(fields: [inspectionLotId], references: [id], onDelete: Cascade)
}

model NonConformance {
  id              String   @id @default(uuid())
  tenantId        String
  ncNumber        String
  inspectionLotId String?
  description     String
  severity        String   @default("minor") // minor, major, critical
  status          String   @default("open") // open, investigating, corrective_action, closed
  rootCause       String?
  correctiveAction String?
  assignedTo      String?
  dueDate         DateTime?
  closedAt        DateTime?
