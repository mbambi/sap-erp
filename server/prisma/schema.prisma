// ─── Plant Maintenance (PM) ─────────────────────────────────────────

model Equipment {
  id              String   @id @default(uuid())
  tenantId        String
  equipmentNumber String
  description     String
  category        String   // machine, vehicle, instrument, building
  manufacturer    String?
  model           String?
  serialNumber    String?
  plantId         String
  location        String?
  installDate     DateTime?
  warrantyEnd     DateTime?
  status          String   @default("active") // active, inactive, under_maintenance, decommissioned
  criticality     String   @default("medium") // low, medium, high, critical
  costCenterId    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  plant      Plant       @relation(fields: [plantId], references: [id])
  workOrders WorkOrder[]
  maintenancePlans MaintenancePlan[]

  @@unique([tenantId, equipmentNumber])
}

model WorkOrder {
  id            String   @id @default(uuid())
  tenantId      String
  woNumber      String
  equipmentId   String
  type          String   // corrective, preventive, inspection, calibration
  priority      String   @default("medium") // low, medium, high, urgent
  description   String
  status        String   @default("open") // open, in_progress, on_hold, completed, cancelled
  plannedStart  DateTime?
  plannedEnd    DateTime?
  actualStart   DateTime?
  actualEnd     DateTime?
  estimatedHours Float?
  actualHours   Float?
  estimatedCost Float?
  actualCost    Float?
  assignedTo    String?
  notes         String?
  createdBy     String
